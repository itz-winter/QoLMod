{
  "schemaVersion": 1,
  "id": "qolmod",
  "version": "${version}",
  "name": "QoL Mod",
  "description": "Quality of Life mod for Minecraft",
  "authors": ["QoLMod Team"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/qolmod/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.qolmod.QoLMod"],
